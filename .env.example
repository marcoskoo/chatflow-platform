# ChatFlow Platform - Environment Variables
#
# In Vercel: Project Settings > Environment Variables
# ─────────────────────────────────────────────────

# ─── Database (REQUIRED) ──────────────────────────────────────────────────────
# Use Vercel Postgres, Neon, Supabase, or any PostgreSQL provider
#
# DATABASE_URL  → pooled connection string (used at runtime by serverless fns)
#                 For Neon: append ?sslmode=require&pgbouncer=true&connect_timeout=15
# DIRECT_URL    → direct (unpooled) connection (used by `prisma migrate deploy`
#                 during build and by `prisma db push`)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── GLM / Z.ai API (OPTIONAL) ────────────────────────────────────────────────
# Used by /api/ai/chat and /api/ai/suggest endpoints.
# If not set, the SDK fallback (z-ai-web-dev-sdk) is used when available.
GLM_API_KEY="your-glm-api-key-here"
GLM_API_URL="https://open.bigmodel.cn/api/paas/v4/chat/completions"

# ─── Node environment (set automatically by Vercel) ──────────────────────────
# NODE_ENV="production"

# ─── Stripe (OPTIONAL — billing) ─────────────────────────────────────────────
# Get your keys from https://dashboard.stripe.com/apikeys
# Create products + prices in Stripe Dashboard, then copy the price IDs here.
#
# STRIPE_SECRET_KEY="sk_live_xxxxxxxxxxxx"  (or sk_test_ for test mode)
# STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"  (from Stripe CLI: stripe listen --forward-to localhost:3000/api/stripe/webhook)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_xxxxxxxxxxxx"
#
# Plan price IDs (monthly + annual)
# NOTE: Since the Subscription panel was added, plan price IDs are editable
# directly from the admin UI (Administración → Suscripciones → Planes).
# These env vars are only used as the initial fallback on first run.
# STRIPE_PRICE_PRO_MONTHLY="price_xxx"
# STRIPE_PRICE_PRO_ANNUAL="price_xxx"
# STRIPE_PRICE_BUSINESS_MONTHLY="price_xxx"
# STRIPE_PRICE_BUSINESS_ANNUAL="price_xxx"

# ─── Manual Payment Methods (Yape / Plin / Bank Transfer) ───────────────────
# These methods do NOT require any environment variable. They are configured
# entirely from the admin UI (Administración → Suscripciones → Métodos de Pago).
#
# The admin enters for each method:
#   - bank_transfer: bank name, account number, CCI, holder info
#   - yape: phone, holder info, optional QR image URL
#   - plin:  phone, holder info, optional QR image URL
#   - stripe: mode (test/live), optional publishable key (for display only)
#
# When a customer pays via Yape/Plin/Transfer, they report the operation
# number. The admin verifies the payment in the "Pagos por Verificar" tab
# and the subscription is activated.

# ─── SUNAT Electronic Invoicing (Perú) (OPTIONAL — disabled by default) ─────
# SUNAT está DESACTIVADO por defecto. Stripe billing funciona sin SUNAT.
# Para activar la generación automática de comprobantes (Factura/Boleta)
# cuando se paga una factura Stripe, setear SUNAT_ENABLED=1 y completar
# los datos del emisor abajo.
#
# SUNAT_ENABLED="1"   # 1 = activado, 0 o ausente = desactivado
#
# Datos del emisor (tu empresa). Requerido SOLO si SUNAT_ENABLED=1.
# SUNAT_ISSUER_RUC="20123456789"
# SUNAT_ISSUER_RAZON_SOCIAL="Mi Empresa SAC"
# SUNAT_ISSUER_NOMBRE_COMERCIAL="Mi Empresa"
# SUNAT_ISSUER_DIRECCION="Av. Javier Prado 1234"
# SUNAT_ISSUER_DEPARTAMENTO="LIMA"
# SUNAT_ISSUER_PROVINCIA="LIMA"
# SUNAT_ISSUER_DISTRITO="San Isidro"
# SUNAT_ISSUER_UBIGEO="150131"
#
# Servicio externo que firma con certificado digital y envía a SUNAT.
# Puede ser Nubefact, Greenter, o un microservicio propio. Si no se
# configura, los comprobantes se generan en modo "simulación".
# SUNAT_SENDER_URL="https://your-sender-endpoint/api/send"
# SUNAT_SENDER_TOKEN="bearer-token"

# ─── App URL (OPTIONAL — used by Stripe redirect URLs) ───────────────────────
# NEXT_PUBLIC_APP_URL="https://your-domain.com"

# ─── E2E tests (OPTIONAL) ────────────────────────────────────────────────────
# ADMIN_API_KEY="cf_xxx"  — used by Playwright tests as Bearer token
# BASE_URL="http://localhost:3000"  — override for tests against preview deploys
